# Copy to `.env` for local runs only — never commit `.env` (see backend/SECRETS.md).
# On Render, add GROQ_API_KEY in Environment / Secrets (encrypted at rest there).

# --- Recommended: Groq (fast, free tier, small models — no OpenAI account) ---
# Create a key at https://console.groq.com
GROQ_API_KEY=

# Default model on Groq (lightweight 8B; change if needed)
# GROQ_MODEL=llama-3.1-8b-instant

# --- Optional: pick provider explicitly (default: infer from keys; else groq) ---
# LLM_PROVIDER=groq
# LLM_PROVIDER=openai
# LLM_PROVIDER=ollama

# --- Only if LLM_PROVIDER=openai ---
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Only if LLM_PROVIDER=ollama (local, no cloud key) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2

# Max concurrent LLM calls per worker (default: 32)
# CHAT_MAX_CONCURRENT=32

# Per-IP rate limit (slowapi)
# RATE_LIMIT_PER_IP=30/minute

# Client timeouts / retries
# LLM_TIMEOUT_SEC=60
# LLM_MAX_RETRIES=2

# Gunicorn workers (Procfile / Render)
# WEB_CONCURRENCY=4
